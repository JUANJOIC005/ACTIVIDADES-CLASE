   "source": [
    "import socket \n",
    "\n",
    "target_ip = \"172.18.0.2\"\n",
    "target_port = 2222\n",
    "\n",
    "with socket.create_connection((target_ip, target_port), timeout=2) as s:\n",
    "    banner = s.recv(1024).decode()\n",
    "    print(f\"Banner: {banner}\")"
   ]
