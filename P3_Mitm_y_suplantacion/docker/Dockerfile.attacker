FROM kalilinux/kali-rolling

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
      bettercap \
      curl \
      iproute2 \
      iputils-ping \
      python3 \
      python3-pip \
      python3-scapy \
      tcpdump \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /lab
